    ) as reflections
  from public.commits c
  join public.profiles p on p.id = c.user_id
  left join public.reflections r
    on r.commit_id = c.id
   and r.deleted_at is null
  where c.id = p_commit_id
    and c.deleted_at is null
  group by c.id, p.id, p.name, p.avatar_url;
$$;

