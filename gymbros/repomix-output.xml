                className="rounded-3xl border border-white/8 bg-white/[0.03] p-4"
                key={support.id}
              >
                <p className="text-sm leading-6 text-primary-text">
                  {support.message}
                </p>
                <p className="mt-2 text-xs font-semibold uppercase tracking-[0.14em] text-secondary-text">
