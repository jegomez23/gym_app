      }),
      ...(parsedInput.data.locale !== undefined && {
        locale: parsedInput.data.locale,
      }),
      ...(parsedInput.data.deletedAt !== undefined && {
        deleted_at: parsedInput.data.deletedAt,
      }),
    };

    const row = unwrapData(
      await this.client
        .from("profiles")
        .update(update)
        .eq("id", parsedId.data)
        .select("*")
        .single()
    );

    return mapProfile(row);
